# Minimal CUDA/Python image for testing the navy-ai Elice bootstrap flow.
#
# This intentionally does not include PyTorch, audio Python packages, project
# repositories, deploy keys, W&B login, or startup bootstrap logic. It should
# behave like a fresh hosted GPU VS Code/SSH environment where the public
# elice_bootstrap.sh script must create the workspace and install dependencies.
FROM nvidia/cuda:11.8.0-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    libsndfile1 \
    make \
    openssh-client \
    python3 \
    python3-pip \
    python3-venv \
    && ln -sf /usr/bin/python3 /usr/local/bin/python \
    && python3 -m pip install --upgrade pip \
    && rm -rf /var/lib/apt/lists/*

CMD ["bash", "-lc", "echo '[elice-test] minimal CUDA/Python container ready'; sleep infinity"]
